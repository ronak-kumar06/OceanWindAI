# Copernicus Data Space Ecosystem (Sentinel-1 SAR)
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# ECMWF Climate Data Store (ERA5 ambiguity resolution)
CDS_KEY=
CDS_URL=https://cds.climate.copernicus.eu/api

# Database — SQLite for local dev, PostgreSQL for production/Docker
DATABASE_URL=sqlite:///./oceanwind.db
# DATABASE_URL=postgresql://oceanwind:oceanwind@localhost:5432/oceanwind

# API server
API_HOST=127.0.0.1
API_PORT=8000
# Public URL used in generated image links (set in production)
API_BASE_URL=http://127.0.0.1:8000

# CORS — comma-separated frontend origins (use * during initial setup)
CORS_ORIGINS=*

# Trained ResNet weights (optional — falls back to simulator if missing)
MODEL_WEIGHTS_PATH=ml/weights/resnet_sar_wind.pth
TRAINING_DATA_DIR=data/training
ASCAT_DATA_DIR=data/ascat
